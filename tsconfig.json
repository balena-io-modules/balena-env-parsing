{
	"compilerOptions": {
		"module": "commonjs",
		"rootDir": "./src",
		"outDir": "build",
		"noUnusedParameters": true,
		"noUnusedLocals": true,
		"sourceMap": true,
		"strict": true,
		"target": "es2019",
		"declaration": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": [
		"src/**/*.ts"
	]
}
